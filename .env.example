# ---------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# Local (docker-compose): puerto 5433 para no chocar con un Postgres del sistema.
# Producción: usar la connection string de Neon/Supabase.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://egmp:egmp_dev_password@localhost:5455/egmp?schema=public"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Auth.js — generar con: openssl rand -base64 32
# ---------------------------------------------------------------------------
AUTH_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"

# Credenciales del admin inicial (usadas por el seed)
ADMIN_EMAIL="admin@elgustodemipueblo.com.ar"
ADMIN_PASSWORD="cambiar-esta-clave"
ADMIN_NAME="Facundo"

# Login de clientes con Google (OPCIONAL, nunca bloqueante).
# Si están vacías, el botón "Continuar con Google" no aparece y el checkout
# funciona igual (guest por teléfono). https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Mercado Pago (sandbox por ahora)
# Obtener en https://www.mercadopago.com.ar/developers
# ---------------------------------------------------------------------------
MP_ACCESS_TOKEN="TEST-xxxxxxxx"
NEXT_PUBLIC_MP_PUBLIC_KEY="TEST-xxxxxxxx"
MP_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Cloudinary (imágenes de producto)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_PRESET="egmp_products"

# ---------------------------------------------------------------------------
# Resend (emails)
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="El Gusto de mi Pueblo <pedidos@elgustodemipueblo.com.ar>"
